@@ -49,6 +51,24 @@ public class ExpoNotificationBuilder extends ChannelAwareNotificationBuilder {
     builder.setAutoCancel(content.isAutoDismiss());
     builder.setOngoing(content.isSticky());

+    // When the notification is sticky, attach a delete intent so that if the OEM
+    // allows the user to swipe it away, our BroadcastReceiver immediately re-posts it.
+    if (content.isSticky()) {
+      byte[] requestBytes = marshallNotificationRequest(getNotification().getNotificationRequest());
+      if (requestBytes != null) {
+        int notifId = getNotification().getNotificationRequest().getIdentifier().hashCode();
+        Intent deleteIntent = new Intent("com.altany.marioshelper.NOTIFICATION_DISMISSED");
+        deleteIntent.setPackage(getContext().getPackageName());
+        deleteIntent.putExtra("requestBytes", requestBytes);
+        deleteIntent.putExtra("notificationId", notifId);
+        PendingIntent deletePendingIntent = PendingIntent.getBroadcast(
+          getContext(),
+          notifId,
+          deleteIntent,
+          PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE
+        );
+        builder.setDeleteIntent(deletePendingIntent);
+      }
+    }
+
     builder.setContentTitle(content.getTitle());
